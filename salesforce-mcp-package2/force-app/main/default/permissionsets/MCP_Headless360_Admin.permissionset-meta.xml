<?xml version="1.0" encoding="UTF-8"?>
<PermissionSet xmlns="http://soap.sforce.com/2006/04/metadata">
    <description>Grants full administrative access to Headless 360 MCP Auto-Registration Apex classes and credentials API.</description>
    <label>MCP Headless 360 Admin Access</label>
    <classAccesses>
        <apexClass>MCPAutoRegisterInstaller</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>MCPHeadless360Controller</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>MCPOpenAPIService</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>MCPHeadless360ToolsService</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <hasActivationRequired>false</hasActivationRequired>
</PermissionSet>
